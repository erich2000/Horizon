{% doc %}
  Multi-image slideshow slide block.

  Structure mirrors ascentprotein.com product-5050:
  - product image is IN FLOW (block element, 540px tall) — gives the slide its height
  - shop-now CTA is position:absolute at bottom, z-index 1
  - layover panel is position:absolute full-cover, z-index 2, fades in on hover (desktop only)

  @example {% content_for 'block', type: '_multi-slide', id: 'slide-1' %}
{% enddoc %}

{%- assign block_index = section.blocks | find_index: 'id', block.id -%}

{%- liquid
  if block.settings.product != blank
    assign slide_url = block.settings.product.url
  elsif block.settings.button_link != blank
    assign slide_url = block.settings.button_link
  endif

  assign base_img = block.settings.image
  unless base_img
    if block.settings.product != blank
      assign base_img = block.settings.product.featured_image
    endif
  endunless

  assign hover_img = block.settings.layover_image
-%}

{% capture children %}
  {%- comment -%}
    Product image — in the document flow, gives the slide its 540px height.
    Matches source: display:block, height:540px, max-height:540px, object-fit:cover.
  {%- endcomment -%}
  {%- if base_img -%}
    {%- liquid
      assign img = base_img
      assign sizes = '(min-width: 750px) 50vw, 85vw'
      assign widths = '375,550,750,1100,1500'
      assign loading = 'lazy'
      assign fetchpriority = 'low'
      assign section_index = section.index

      if block_index == 0 and section_index <= 3
        assign loading = 'eager'
      endif

      if block_index == 0 and section_index == 1
        assign fetchpriority = 'high'
      endif
    -%}
    {{
      img
      | image_url: width: img.width
      | image_tag:
        sizes: sizes,
        widths: widths,
        class: 'multi-slide__image',
        loading: loading,
        fetchpriority: fetchpriority,
        alt: img.alt
    }}
  {%- else -%}
    {%- liquid
      assign modulo_result = block_index | modulo: 2
      assign placeholder_variant = 2 | minus: modulo_result
      assign placeholder_name = 'hero-apparel-' | append: placeholder_variant
    -%}
    {{ placeholder_name | placeholder_svg_tag: 'multi-slide__image' }}
  {%- endif -%}

  {%- comment -%} Base CTA — always visible, sits above the image (z-index 1) {%- endcomment -%}
  {%- if block.settings.shop_now_text != blank -%}
    <a
      {% if slide_url %}href="{{ slide_url }}"{% endif %}
      class="multi-slide__shop-cta"
    >
      {{ block.settings.shop_now_text | escape }}
    </a>
  {%- endif -%}

  {%- comment -%} Layover — hover bg + text + CTA; desktop: opacity 0→1 on hover; mobile: always visible {%- endcomment -%}
  <div
    class="multi-slide__layover{% if hover_img %} multi-slide__layover--has-image{% endif %}"
    {% if hover_img %}
      style="--layover-bg: url('{{ hover_img | image_url: width: 1500 }}')"
    {% endif %}
    {{ block.shopify_attributes }}
  >
    <div class="multi-slide__layover-inner">
      {%- if block.settings.subheading != blank -%}
        <p class="multi-slide__subheading">{{ block.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if block.settings.heading != blank -%}
        <h2 class="multi-slide__heading">{{ block.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if block.settings.description != blank -%}
        <p class="multi-slide__description">{{ block.settings.description | escape }}</p>
      {%- endif -%}

      {%- if block.settings.stat_1_value != blank or block.settings.stat_2_value != blank or block.settings.stat_3_value != blank -%}
        <div class="multi-slide__stats">
          {%- if block.settings.stat_1_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_1_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_1_label | escape }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.stat_2_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_2_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_2_label | escape }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.stat_3_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_3_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_3_label | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if block.settings.button_text != blank -%}
        <a
          {% if slide_url %}href="{{ slide_url }}"{% endif %}
          class="multi-slide__button"
        >
          {{ block.settings.button_text | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
{% endcapture %}

{% render 'slideshow-slide',
  index: block_index,
  children: children,
  attributes: block.shopify_attributes,
  navigate_to_slide: true
%}

{% stylesheet %}
  /* ── SLIDE CONTAINER ── */
  slideshow-slide {
    position: relative;
    overflow: hidden;
  }

  /* ── PRODUCT IMAGE (in flow — gives slide its height, matches source) ── */
  .multi-slide__image,
  .multi-slide__image-container > svg {
    display: block;
    width: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* ── BASE CTA ── */
  .multi-slide__shop-cta {
    display: block;
    max-width: 356px;
    padding: 10px 30px;
    background-color: var(--multi-slide-button-bg, #F3E200);
    color: var(--multi-slide-button-color, #00000E);
    border-radius: 35px;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .multi-slide__shop-cta:hover {
    opacity: 0.85;
  }

  /* ── LAYOVER ── */
  .multi-slide__layover {
    background-image: var(--layover-bg);
    background-size: cover;
    background-position: center;
    position: relative;
  }

  .multi-slide__layover--has-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 14, 0.4);
    z-index: 0;
    pointer-events: none;
  }

  .multi-slide__layover-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px 10px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* ── TYPOGRAPHY ── */
  .multi-slide__subheading {
    margin-block-start: 16px;
    margin-block-end: 0;
    font-size: 10px;
    font-weight: 800;
    line-height: 23px;
    letter-spacing: 1.7px;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .multi-slide__heading {
    margin-block-start: 0;
    margin-block-end: 8px;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground);
    font-family: var(--font-heading--family);
  }

  .multi-slide__description {
    margin-block-start: 16px;
    margin-block-end: 20px;
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    max-width: 336px;
  }

  /* ── STATS ── */
  .multi-slide__stats {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-block-start: 16px;
    margin-block-end: 24px;
  }

  .multi-slide__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border: 1px solid var(--color-foreground);
    border-radius: 12px;
    padding: 8px;
  }

  .multi-slide__stat-value {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground);
  }

  .multi-slide__stat-label {
    font-size: 10px;
    line-height: 1.3;
    color: var(--color-foreground);
    text-align: center;
  }

  /* ── LAYOVER BUTTON ── */
  .multi-slide__button {
    display: block;
    width: 100%;
    max-width: 356px;
    padding: 10px 30px;
    background-color: var(--multi-slide-button-bg, #F3E200);
    color: var(--multi-slide-button-color, #00000E);
    border-radius: 35px;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    cursor: pointer;
    margin-block-start: auto;
    transition: opacity 0.2s ease;
  }

  .multi-slide__button:hover {
    opacity: 0.85;
  }

  /* ── DESKTOP ── */
  @media screen and (min-width: 750px) {
    /* Image: in flow, explicit 540px height — matches source exactly */
    .multi-slide__image {
      height: 540px;
      max-height: 540px;
    }

    /* SVG placeholder same height */
    .multi-slide__image-container > svg {
      height: 540px;
    }

    /* Base CTA: absolute at bottom, z-index 1 (above image, below layover) */
    .multi-slide__shop-cta {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 356px;
      z-index: 1;
    }

    /* Layover: full cover, hidden by default, fades in on hover */
    .multi-slide__layover {
      position: absolute;
      inset: 0;
      z-index: 2;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    slideshow-slide:hover .multi-slide__layover {
      opacity: 1;
      pointer-events: auto;
    }

    /* White text for readability over dark backgrounds */
    .multi-slide__layover .multi-slide__subheading,
    .multi-slide__layover .multi-slide__heading,
    .multi-slide__layover .multi-slide__description,
    .multi-slide__layover .multi-slide__stat-value,
    .multi-slide__layover .multi-slide__stat-label {
      color: #fff;
    }

    .multi-slide__layover .multi-slide__stat {
      border-color: rgba(255, 255, 255, 0.7);
    }

    /* Layover inner: full-height column */
    .multi-slide__layover-inner {
      width: 100%;
      max-width: 356px;
      height: 100%;
      padding: 0 10px;
    }

    /* Layover button: absolute at bottom (same y-position as base CTA) */
    .multi-slide__button {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 356px;
    }

    .multi-slide__heading {
      font-size: 33px;
      line-height: 39.5px;
    }

    .multi-slide__description {
      font-size: 16px;
      line-height: 25.5px;
    }
  }

  /* Reduced motion: skip fade, layover always visible */
  @media screen and (min-width: 750px) and (prefers-reduced-motion: reduce) {
    .multi-slide__layover {
      transition: none;
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* ── MOBILE ── */
  @media screen and (max-width: 749px) {
    .multi-slide__image {
      aspect-ratio: 270 / 390;
      height: auto;
    }

    /* Hide base CTA on mobile — layover's button is used instead */
    .multi-slide__shop-cta {
      display: none;
    }

    /* Layover: always visible, no bg image, stacked below image */
    .multi-slide__layover {
      background-image: none;
      padding-block-end: 16px;
    }

    .multi-slide__layover--has-image::before {
      display: none;
    }

    /* Restore theme foreground color on mobile */
    .multi-slide__layover .multi-slide__subheading,
    .multi-slide__layover .multi-slide__heading,
    .multi-slide__layover .multi-slide__description,
    .multi-slide__layover .multi-slide__stat-value,
    .multi-slide__layover .multi-slide__stat-label {
      color: var(--color-foreground);
    }

    .multi-slide__layover .multi-slide__stat {
      border-color: var(--color-foreground);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Multi-image slide",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Sets the link for both CTAs. Featured image used if no image is set below."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image",
      "info": "Base background (always visible). Falls back to product featured image."
    },
    {
      "type": "image_picker",
      "id": "layover_image",
      "label": "Hover background image",
      "info": "Displayed as background on hover only. Leave empty to keep product image on hover."
    },
    {
      "type": "text",
      "id": "shop_now_text",
      "label": "Base CTA text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link override",
      "info": "Overrides product URL when set"
    },
    {
      "type": "header",
      "content": "Layover Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Post Workout Recovery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Whey Protein"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "25g of clean, delicious, fast-digesting whey protein to help your muscles recover from intense workouts"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "25g of"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Protein"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "5.5g of"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "BCAA's"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "0g of"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Added Sugar"
    },
    {
      "type": "header",
      "content": "Layover Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Multi-image slide"
    }
  ]
}
{% endschema %}
