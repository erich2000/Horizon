{% doc %}
  Multi-image slideshow slide block.

  Renders a slide with product image, text content overlay (subheading, heading,
  description, stat badges, CTA button). On desktop the content overlays the image
  with scroll-linked fade-in animation. On mobile the image and content are stacked.

  @example {% content_for 'block', type: '_multi-slide', id: 'slide-1' %}
{% enddoc %}

{%- assign block_index = section.blocks | find_index: 'id', block.id -%}

{% capture children %}
  <div class="multi-slide__image-container">
    {%- if block.settings.image -%}
      {%- liquid
        assign img = block.settings.image
        assign height = img.width | divided_by: img.aspect_ratio | round
        assign sizes = '(min-width: 750px) 50vw, 85vw'
        assign widths = '375,550,750,1100,1500'
        assign loading = 'lazy'
        assign fetchpriority = 'low'
        assign section_index = section.index

        if block_index == 0 and section_index <= 3
          assign loading = 'eager'
        endif

        if block_index == 0 and section_index == 1
          assign fetchpriority = 'high'
        endif
      -%}
      {{
        img
        | image_url: width: img.width
        | image_tag:
          height: height,
          sizes: sizes,
          widths: widths,
          class: 'multi-slide__image',
          loading: loading,
          fetchpriority: fetchpriority,
          alt: img.alt
      }}
    {%- else -%}
      {%- liquid
        assign modulo_result = block_index | modulo: 2
        assign placeholder_variant = 2 | minus: modulo_result
        assign placeholder_name = 'hero-apparel-' | append: placeholder_variant
      -%}
      {{ placeholder_name | placeholder_svg_tag: 'multi-slide__image' }}
    {%- endif -%}
  </div>

  <div class="multi-slide__content" {{ block.shopify_attributes }}>
    <div class="multi-slide__content-inner">
      {%- if block.settings.subheading != blank -%}
        <p class="multi-slide__subheading">{{ block.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if block.settings.heading != blank -%}
        <h2 class="multi-slide__heading">{{ block.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if block.settings.description != blank -%}
        <p class="multi-slide__description">{{ block.settings.description | escape }}</p>
      {%- endif -%}

      {%- if block.settings.stat_1_value != blank -%}
        <div class="multi-slide__stats">
          {%- if block.settings.stat_1_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_1_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_1_label | escape }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.stat_2_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_2_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_2_label | escape }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.stat_3_value != blank -%}
            <div class="multi-slide__stat">
              <span class="multi-slide__stat-value">{{ block.settings.stat_3_value | escape }}</span>
              <span class="multi-slide__stat-label">{{ block.settings.stat_3_label | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if block.settings.button_text != blank -%}
        <a
          {% if block.settings.button_link != blank %}
            href="{{ block.settings.button_link }}"
          {% endif %}
          class="multi-slide__button"
        >
          {{ block.settings.button_text | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
{% endcapture %}

{% render 'slideshow-slide',
  index: block_index,
  children: children,
  attributes: block.shopify_attributes,
  navigate_to_slide: true
%}

{% stylesheet %}
  .multi-slide__image-container {
    display: flex;
    width: 100%;
    overflow: hidden;
  }

  .multi-slide__image,
  .multi-slide__image-container > svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .multi-slide__content {
    position: relative;
    z-index: var(--layer-flat, 1);
  }

  .multi-slide__content-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px 10px;
    text-align: center;
  }

  .multi-slide__subheading {
    margin-block-start: 16px;
    margin-block-end: 0;
    font-size: 10px;
    font-weight: 800;
    line-height: 23px;
    letter-spacing: 1.7px;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .multi-slide__heading {
    margin-block-start: 0;
    margin-block-end: 8px;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground);
    font-family: var(--font-heading--family);
  }

  .multi-slide__description {
    margin-block-start: 16px;
    margin-block-end: 20px;
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    max-width: 336px;
  }

  .multi-slide__stats {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-block-start: 16px;
    margin-block-end: 24px;
  }

  .multi-slide__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border: 1px solid var(--color-foreground);
    border-radius: 12px;
    padding: 8px;
  }

  .multi-slide__stat-value {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground);
  }

  .multi-slide__stat-label {
    font-size: 10px;
    line-height: 1.3;
    color: var(--color-foreground);
    text-align: center;
  }

  .multi-slide__button {
    display: block;
    width: 100%;
    max-width: 356px;
    padding: 10px 30px;
    background-color: var(--multi-slide-button-bg, #F3E200);
    color: var(--multi-slide-button-color, #00000E);
    border-radius: 35px;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    cursor: pointer;
    margin-block-start: auto;
    transition: opacity 0.2s ease;
  }

  .multi-slide__button:hover {
    opacity: 0.85;
  }

  /* Desktop: overlay content on image */
  @media screen and (min-width: 750px) {
    .multi-slide__image-container {
      position: absolute;
      inset: 0;
      height: 100%;
    }

    .multi-slide__content {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @supports (animation-timeline: auto) {
      .multi-slide__content {
        opacity: 0;
        animation: slide-reveal both linear;
        animation-timeline: var(--slideshow-timeline);
      }
    }

    @media (prefers-reduced-motion) {
      .multi-slide__content {
        opacity: 1;
        animation: none;
      }
    }

    .multi-slide__content-inner {
      max-width: 356px;
      height: 100%;
      padding: 0 10px;
    }

    .multi-slide__heading {
      font-size: 33px;
      line-height: 39.5px;
    }

    .multi-slide__description {
      font-size: 16px;
      line-height: 25.5px;
    }

    .multi-slide__button {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 356px;
    }
  }

  /* Mobile: stacked layout */
  @media screen and (max-width: 749px) {
    .multi-slide__image-container {
      position: relative;
      height: auto;
      aspect-ratio: 270 / 390;
    }

    .multi-slide__content {
      position: relative;
      padding-block-end: 16px;
    }

    .multi-slide__content-inner {
      padding: 16px 10px;
    }
  }

  /* Force content visible when animation-timeline unsupported */
  @supports not (animation-timeline: auto) {
    .multi-slide__content {
      opacity: 1;
    }
  }

  /* Reduced motion fallback */
  @media (prefers-reduced-motion) {
    .multi-slide__content {
      opacity: 1;
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Multi-image slide",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Post Workout Recovery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Whey Protein"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "25g of clean, delicious, fast-digesting whey protein to help your muscles recover from intense workouts"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "25g of"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Protein"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "5.5g of"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "BCAA's"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "0g of"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Added Sugar"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Multi-image slide"
    }
  ]
}
{% endschema %}
