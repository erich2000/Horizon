{% liquid
  assign slide_count = section.blocks.size
%}

{% capture controls %}
  {%- render 'slideshow-controls',
    style: 'dots',
    autoplay: section.settings.autoplay,
    item_count: slide_count,
    show_arrows: false,
    pagination_position: 'center'
  -%}
{% endcapture %}

{% capture slides %}
  {% for block in section.blocks %}
    {% capture slide_content %}
      <div class="reviews-highlight__slide-content">
        <div class="reviews-highlight__stars" aria-hidden="true">
          {% for i in (1..block.settings.stars) %}
            <svg
              class="reviews-highlight__star-icon"
              aria-hidden="true"
              focusable="false"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
            >
              {%- render 'icon', icon: 'star' -%}
            </svg>
          {% endfor %}
        </div>
        <span class="visually-hidden">{{ block.settings.stars }} out of 5 stars</span>

        {% if block.settings.quote != blank %}
          <blockquote class="reviews-highlight__quote">
            <p class="reviews-highlight__quote-text">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          </blockquote>
        {% endif %}

        {% if block.settings.read_more_url != blank %}
          <a href="{{ block.settings.read_more_url }}" class="reviews-highlight__read-more">Read more</a>
        {% endif %}

        {% if block.settings.author != blank %}
          <cite class="reviews-highlight__author">&mdash; {{ block.settings.author }}</cite>
        {% endif %}
      </div>
    {% endcapture %}

    {%- render 'slideshow-slide',
      index: forloop.index0,
      children: slide_content,
      attributes: block.shopify_attributes
    -%}
  {% endfor %}
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="reviews-highlight spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --reviews-dot-active-color: {{ section.settings.dot_active_color }};
  "
>
  {% if section.settings.heading != blank %}
    <h2 class="reviews-highlight__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if slide_count > 0 %}
    <div class="reviews-highlight__carousel-wrapper">
      {% render 'slideshow',
        slides: slides,
        slide_count: slide_count,
        controls: controls,
        show_arrows: false,
        autoplay: section.settings.autoplay,
        autoplay_speed: section.settings.autoplay_speed,
        infinite: true
      %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .reviews-highlight {
    text-align: center;
  }

  .reviews-highlight__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 46px;
    line-height: 1.1;
    text-transform: uppercase;
    margin: 0 0 50px;
    text-align: center;
  }

  .reviews-highlight__carousel-wrapper {
    max-width: 680px;
    margin-inline: auto;
    position: relative;
  }

  .reviews-highlight__slide-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .reviews-highlight__stars {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2px;
    margin-block-end: 20px;
  }

  .reviews-highlight__star-icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .reviews-highlight__quote {
    margin: 0;
    padding-inline: 10px;
  }

  .reviews-highlight__quote-text {
    font-family: var(--font-body--family);
    font-size: 32px;
    font-weight: 700;
    line-height: 37.5px;
    text-align: center;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .reviews-highlight__read-more {
    display: inline-block;
    font-family: var(--font-body--family);
    font-size: 16px;
    line-height: 25.6px;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    text-decoration: none;
    margin-block-start: 10px;
    margin-block-end: 20px;

    &:hover {
      text-decoration: underline;
    }
  }

  .reviews-highlight__author {
    font-family: var(--font-body--family);
    font-size: 16px;
    font-weight: 700;
    line-height: 26px;
    letter-spacing: 0.4px;
    font-style: normal;
    text-align: center;
  }

  /* Slideshow container background override — make transparent */
  .reviews-highlight slideshow-container {
    background-color: transparent;
  }

  /* Override mix-blend-mode on controls within this section */
  .reviews-highlight slideshow-controls:has(.slideshow-controls__dots),
  .reviews-highlight slideshow-component[autoplay] slideshow-controls {
    mix-blend-mode: normal;
  }

  /* Override dot colors */
  .reviews-highlight .slideshow-controls__dots button {
    --color: var(--color-foreground);
    --color-active: var(--reviews-dot-active-color, #f3e200);
    --color-hover: var(--color-foreground);
  }

  /* Remove inset box-shadow on dots */
  .reviews-highlight .slideshow-controls__dots button::after {
    box-shadow: none;
  }

  .reviews-highlight .slideshow-controls__dots button[aria-selected='true']::after {
    box-shadow: none;
  }

  /* Autoplay pause/play button styling */
  .reviews-highlight .slideshow-control:is(.icon-pause, .icon-play) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid var(--color-foreground);
    background-color: var(--color-background);
    color: var(--color-foreground);

    &:hover {
      opacity: 0.7;
    }

    svg {
      width: 70%;
      height: 70%;
    }
  }

  /* Hide inactive autoplay button to prevent ghost box */
  .reviews-highlight slideshow-component[autoplay]:not([paused]) .icon-play {
    display: none;
  }

  .reviews-highlight slideshow-component[autoplay][paused] .icon-pause {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .reviews-highlight__heading {
      font-size: 23px;
      line-height: 28px;
      margin-block-end: 30px;
    }

    .reviews-highlight__quote-text {
      font-size: 16px;
      line-height: 18px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews highlight",
  "tag": "section",
  "class": "reviews-highlight-wrapper section-wrapper",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "url",
          "id": "read_more_url",
          "label": "Read more link"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#f3e200"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Reviews highlight",
      "category": "Social proof",
      "blocks": {
        "slide_1": {
          "type": "review",
          "settings": {
            "stars": 5,
            "quote": "Best protein powder I've tried! I've tried so many brands from Optimum Nutrition, Ghost, Podium, 1st Phorm and more. This one takes the cake and I'll never go back to any other brand.",
            "author": "Sydney"
          }
