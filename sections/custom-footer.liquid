{% style %}
  .shopify-section-{{ section.id }} .custom-footer {
    --cf-logo-max-width: {{ section.settings.logo_max_width }}px;
    --cf-badge-width: {{ section.settings.badge_width }}px;
  }
{% endstyle %}

<div
  class="custom-footer spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="custom-footer__inner">
    <div class="custom-footer__columns" style="--cf-menu-count: {{ section.blocks.size }};">
      {%- comment -%} Logo column — desktop only {%- endcomment -%}
      <div class="custom-footer__logo-col">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: 'Logo' -%}
          <a href="/" class="custom-footer__logo-link">
            {{ section.settings.logo | image_url: width: section.settings.logo_max_width | image_tag: alt: logo_alt, loading: 'lazy', class: 'custom-footer__logo-img' }}
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Menu columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div
            class="custom-footer__menu-col"
            style="--cf-menu-spacing: {{ block.settings.menu_spacing }}px;"
            {{ block.shopify_attributes }}
          >
            {%- capture menu_content -%}
              <details class="custom-footer__details" open>
                <summary class="custom-footer__summary">
                  <span class="custom-footer__heading-desktop">{{ block.settings.heading }}</span>
                  <span class="custom-footer__heading-mobile">
                    {{ block.settings.heading }}
                    <span class="custom-footer__caret svg-wrapper icon-caret icon-animated">
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </span>
                  </span>
                </summary>
                <div class="details-content">
                  <nav class="custom-footer__links-nav">
                    {%- assign footer_menu = linklists[block.settings.menu] -%}
                    {%- if footer_menu != blank -%}
                      <ul class="custom-footer__links list-unstyled">
                        {%- for link in footer_menu.links -%}
                          <li class="custom-footer__link-item">
                            <a href="{{ link.url }}">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if block.settings.show_social -%}
                      {%- liquid
                        assign social_keys = 'facebook_url,twitter_url,instagram_url,youtube_url' | split: ','
                        assign has_any_social = false
                        for skey in social_keys
                          if section.settings[skey] != blank
                            assign has_any_social = true
                            break
                          endif
                        endfor
                      -%}
                      {%- if has_any_social -%}
                        <div class="custom-footer__social">
                          {%- for skey in social_keys -%}
                            {%- assign social_url = section.settings[skey] -%}
                            {%- if social_url != blank -%}
                              {%- liquid
                                case skey
                                  when 'facebook_url'
                                    assign platform_name = 'facebook'
                                  when 'twitter_url'
                                    assign platform_name = 'twitter'
                                  when 'instagram_url'
                                    assign platform_name = 'instagram'
                                  when 'youtube_url'
                                    assign platform_name = 'youtube'
                                endcase
                              -%}
                              <a
                                href="{{ social_url }}"
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="{{ platform_name | capitalize }}"
                                class="custom-footer__social-link"
                              >
                                <svg
                                  class="custom-footer__social-icon"
                                  aria-hidden="true"
                                  focusable="false"
                                  xmlns="http://www.w3.org/2000/svg"
                                  viewBox="0 0 20 20"
                                >
                                  {%- render 'icon', icon: platform_name -%}
                                </svg>
                              </a>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  </nav>
                </div>
              </details>
            {%- endcapture -%}
            {%- render 'accordion-custom-component',
              children: menu_content,
              class: 'custom-footer__menu',
              disable_on_desktop: true,
              open_by_default_on_desktop: true
            -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile logo — hidden on desktop {%- endcomment -%}
    <div class="custom-footer__logo-mobile">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt_mobile = section.settings.logo.alt | default: 'Logo' -%}
        <a href="/" class="custom-footer__logo-link">
          {{ section.settings.logo | image_url: width: section.settings.logo_max_width | image_tag: alt: logo_alt_mobile, loading: 'lazy', class: 'custom-footer__logo-img' }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="custom-footer__bottom">
      <div class="custom-footer__copyright">
        <p>{{ section.settings.copyright_text }}</p>
      </div>
      <div class="custom-footer__bottom-right">
        {%- if section.settings.badge_link != blank -%}
          <a href="{{ section.settings.badge_link }}" target="_blank" rel="noopener noreferrer" class="custom-footer__badge-link">
        {%- endif -%}
          {%- if section.settings.badge_image != blank -%}
            {%- assign badge_alt = section.settings.badge_image.alt | default: 'Badge' -%}
            {{ section.settings.badge_image | image_url: width: section.settings.badge_width | image_tag: alt: badge_alt, loading: 'lazy', class: 'custom-footer__badge-img' }}
          {%- else -%}
            <img
              src="{{ 'allyant-badge-780741d02a85.svg' | asset_url }}"
              alt="Reviewed by Allyant for Accessibility"
              loading="lazy"
              class="custom-footer__badge-img"
            >
          {%- endif -%}
        {%- if section.settings.badge_link != blank -%}
          </a>
        {%- endif -%}

        {%- assign policy_menu = linklists[section.settings.policy_menu] -%}
        {%- if policy_menu != blank and policy_menu.links.size > 0 -%}
          <ul class="custom-footer__policies list-unstyled">
            {%- for link in policy_menu.links -%}
              <li class="custom-footer__policy-item">
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* Custom Footer — main layout */
  .custom-footer__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding-inline: 40px;
  }

  /* Columns grid */
  .custom-footer__columns {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__columns {
      grid-template-columns: 1.25fr repeat(var(--cf-menu-count, 3), 1fr);
    }
  }

  /* Desktop logo column */
  .custom-footer__logo-col {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__logo-col {
      display: block;
    }
  }

  .custom-footer__logo-link {
    display: inline-block;
  }

  .custom-footer__logo-img {
    max-width: var(--cf-logo-max-width, 77px);
    height: auto;
  }

  /* Mobile logo */
  .custom-footer__logo-mobile {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-block: 20px;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__logo-mobile {
      display: none;
    }
  }

  /* Menu column */
  .custom-footer__menu-col {
    width: 100%;
  }

  .custom-footer__menu {
    width: 100%;
  }

  /* Details / accordion */
  .custom-footer__details {
    width: 100%;
  }

  /* Summary — heading */
  .custom-footer__summary {
    list-style: none;
    cursor: pointer;
  }

  .custom-footer__summary::-webkit-details-marker {
    display: none;
  }

  .custom-footer__summary::marker {
    display: none;
    content: '';
  }

  /* Desktop heading style */
  .custom-footer__heading-desktop {
    display: none;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    font-size: 15px;
    line-height: 18px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  @media screen and (min-width: 750px) {
    .custom-footer__heading-desktop {
      display: contents;
    }

    .custom-footer__summary {
      cursor: auto;
      margin-block-end: 20px;
    }
  }

  /* Mobile heading style */
  .custom-footer__heading-mobile {
    display: contents;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    font-size: 15px;
    line-height: 18px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  @media screen and (min-width: 750px) {
    .custom-footer__heading-mobile {
      display: none;
    }
  }

  /* Mobile accordion styling */
  @media screen and (max-width: 749px) {
    .custom-footer__summary {
      position: relative;
      padding-block: 20px;
    }

    .custom-footer__details {
      border-block-end: 1px solid var(--color-border);
    }

    .custom-footer__caret {
      position: absolute;
      inset-inline-end: 0;
      inset-block-start: 50%;
      transform: translateY(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      transition: transform 0.2s ease;

      svg {
        width: 14px;
        height: 14px;
      }
    }

    .custom-footer__details[open] .custom-footer__caret {
      transform: translateY(-50%) rotate(180deg);
    }

    .custom-footer__details .details-content {
      padding-block-end: 16px;
    }
  }

  /* Links nav */
  .custom-footer__links-nav {
    width: 100%;
  }

  .custom-footer__link-item {
    margin-block-end: var(--cf-menu-spacing, 4px);
  }

  .custom-footer__link-item a {
    display: inline-block;
    padding-block: 4px;
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 22.5px;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .custom-footer__link-item a:hover {
    opacity: 0.8;
  }

  /* Social icons */
  .custom-footer__social {
    display: flex;
    gap: 15px;
    margin-block-start: 20px;
  }

  .custom-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .custom-footer__social-link:hover {
    opacity: 0.8;
  }

  .custom-footer__social-icon {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  /* Bottom bar */
  .custom-footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-block-start: 30px;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__bottom {
      flex-direction: row;
      align-items: flex-end;
      margin-block-start: 120px;
    }
  }

  /* Copyright */
  .custom-footer__copyright {
    width: 100%;
    text-align: center;

    p {
      margin: 0;
      font-family: var(--font-body--family);
      font-size: 11px;
      line-height: 24px;
      letter-spacing: 1px;
      text-transform: uppercase;
      opacity: 0.7;
      color: var(--color-foreground);
    }
  }

  @media screen and (min-width: 750px) {
    .custom-footer__copyright {
      flex: 1;
      text-align: start;
    }
  }

  /* Bottom right — badge + policies */
  .custom-footer__bottom-right {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 16px;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__bottom-right {
      flex: 1;
      flex-direction: column;
      align-items: flex-end;
      gap: 0;
    }
  }

  /* Badge */
  .custom-footer__badge-link {
    display: inline-block;
  }

  .custom-footer__badge-img {
    width: var(--cf-badge-width, 80px);
    height: auto;
  }

  /* Policy links */
  .custom-footer__policies {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0.7;
  }

  @media screen and (min-width: 750px) {
    .custom-footer__policies {
      justify-content: flex-end;
    }
  }

  .custom-footer__policy-item {
    font-family: var(--font-body--family);
    font-size: 11px;
    line-height: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-block-end: 2.75px;
  }

  .custom-footer__policy-item + .custom-footer__policy-item::before {
    content: '|';
    margin-inline: 5px;
    color: var(--color-foreground);
  }

  .custom-footer__policy-item a {
    color: inherit;
    text-decoration: none;
    margin-inline: 5px;
  }

  .custom-footer__policy-item a:hover {
    opacity: 0.8;
  }

  /* Mobile inner padding */
  @media screen and (max-width: 749px) {
    .custom-footer__inner {
      padding-inline: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom footer",
  "tag": "footer",
  "class": "custom-footer-wrapper",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-10"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "number",
      "id": "logo_max_width",
      "label": "Logo max width (px)",
      "default": 77
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© ALL RIGHTS RESERVED COPYRIGHT 2026 Ascent Protein"
    },
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "Policy links menu"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image"
    },
    {
      "type": "url",
      "id": "badge_link",
      "label": "Badge link"
    },
    {
      "type": "number",
      "id": "badge_width",
      "label": "Badge width (px)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter / X"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Menu"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show social icons",
          "default": false
        },
        {
          "type": "range",
          "id": "menu_spacing",
          "label": "Link spacing",
          "min": 0,
          "max": 50,
          "step": 1,
          "unit": "px",
          "default": 4
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Custom footer",
      "blocks": {
        "menu_shop": {
          "type": "menu",
          "settings": {
            "heading": "SHOP",
            "show_social": false,
            "menu_spacing": 4
          }
        },
        "menu_company": {
          "type": "menu",
          "settings": {
            "heading": "COMPANY",
            "show_social": false,
            "menu_spacing": 4
          }
        },
        "menu_connect": {
          "type": "menu",
          "settings": {
            "heading": "CONNECT",
            "show_social": true,
            "menu_spacing": 4
          }
        }
      },
      "block_order": [
        "menu_shop",
        "menu_company",
        "menu_connect"
      ]
    }
  ]
}
{% endschema %}
