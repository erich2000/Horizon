

{% liquid
  assign section_settings = section.settings
%}

<div class="section-background color-{{ section_settings.color_scheme }}"></div>
<div
  class="section section--full-width color-{{ section_settings.color_scheme }}"
>
  <div
    class="full-width-info-banner spacing-style"
    style="
      --banner-height: {{ section_settings.min_height }}px;
      --banner-height-mobile: {{ section_settings.min_height_mobile }}px;
      --banner-bg-color: {{ section_settings.background_color }};
      --banner-panel-padding: {{ section_settings.panel_padding }}px;
      --banner-panel-padding-mobile: {{ section_settings.panel_padding_mobile }}px;
      {% render 'spacing-style', settings: section_settings %}
    "
    {{ section.shopify_attributes }}
  >
    {%- comment -%} Background layer {%- endcomment -%}
    <div class="full-width-info-banner__background">
      {% if section_settings.image != blank %}
        <div class="full-width-info-banner__bg-image full-width-info-banner__bg-image--desktop">
          {{
            section_settings.image
            | image_url: width: section_settings.image.width
            | image_tag:
              sizes: '100vw',
              widths: '375,750,1100,1500,1780,2000',
              loading: 'lazy',
              class: 'full-width-info-banner__img',
              alt: section_settings.image.alt
          }}
        </div>
      {% endif %}
      {% if section_settings.image_mobile != blank %}
        <div class="full-width-info-banner__bg-image full-width-info-banner__bg-image--mobile">
          {{
            section_settings.image_mobile
            | image_url: width: section_settings.image_mobile.width
            | image_tag:
              sizes: '100vw',
              widths: '375,550,750',
              loading: 'lazy',
              class: 'full-width-info-banner__img',
              alt: section_settings.image_mobile.alt
          }}
        </div>
      {% endif %}
    </div>

    {%- comment -%} Content layer {%- endcomment -%}
    <div class="full-width-info-banner__content-wrapper full-width-info-banner__content-wrapper--{{ section_settings.content_position }}">
      <div class="full-width-info-banner__panel color-{{ section_settings.color_scheme }}">
        {% if section_settings.subtitle != blank %}
          <p class="full-width-info-banner__subtitle">{{ section_settings.subtitle | escape }}</p>
        {% endif %}

        {% if section_settings.heading != blank %}
          <h2 class="full-width-info-banner__heading">{{ section_settings.heading | escape }}</h2>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="full-width-info-banner__props">
            {% for block in section.blocks %}
              <div class="full-width-info-banner__prop-item" {{ block.shopify_attributes }}>
                {% if block.settings.icon != blank %}
                  <div class="full-width-info-banner__prop-icon">
                    {{
                      block.settings.icon
                      | image_url: width: 76
                      | image_tag:
                        loading: 'lazy',
                        widths: '38,76',
                        sizes: '38px',
                        class: 'full-width-info-banner__prop-icon-img',
                        alt: block.settings.icon.alt
                    }}
                  </div>
                {% endif %}
                {% if block.settings.text != blank %}
                  <span class="full-width-info-banner__prop-text">{{ block.settings.text | escape }}</span>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .full-width-info-banner {
    position: relative;
    min-height: var(--banner-height, 750px);
    overflow: hidden;
  }

  .full-width-info-banner__background {
    position: absolute;
    inset: 0;
    background-color: var(--banner-bg-color, #111111);
    z-index: 0;
  }

  .full-width-info-banner__bg-image {
    position: absolute;
    inset: 0;
  }

  .full-width-info-banner__bg-image--mobile {
    display: none;
  }

  .full-width-info-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .full-width-info-banner__content-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: var(--banner-height, 750px);
    padding: 0 40px;
  }

  /* Desktop content positions */
  .full-width-info-banner__content-wrapper--center-left {
    align-items: center;
    justify-content: flex-start;
  }

  .full-width-info-banner__content-wrapper--center-center {
    align-items: center;
    justify-content: center;
  }

  .full-width-info-banner__content-wrapper--center-right {
    align-items: center;
    justify-content: flex-end;
  }

  .full-width-info-banner__content-wrapper--bottom-left {
    align-items: flex-end;
    justify-content: flex-start;
  }

  .full-width-info-banner__content-wrapper--bottom-center {
    align-items: flex-end;
    justify-content: center;
  }

  .full-width-info-banner__content-wrapper--bottom-right {
    align-items: flex-end;
    justify-content: flex-end;
  }

  .full-width-info-banner__panel {
    padding: var(--banner-panel-padding, 40px);
    max-width: 380px;
  }

  .full-width-info-banner__subtitle {
    font-family: var(--font-heading--family);
    font-weight: 800;
    font-size: 25px;
    line-height: 40px;
    letter-spacing: 1.7px;
    text-align: center;
    text-transform: uppercase;
    margin-block-end: 5px;
  }

  .full-width-info-banner__heading {
    font-family: var(--font-heading--family);
    font-size: 46px;
    line-height: 55px;
    text-align: center;
    margin-block-end: 20px;
  }

  .full-width-info-banner__props {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-block-start: 40px;
  }

  .full-width-info-banner__prop-item {
    display: flex;
    align-items: center;
  }

  .full-width-info-banner__prop-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    margin-inline-end: 15px;
  }

  .full-width-info-banner__prop-icon-img {
    width: 38px;
    height: 38px;
    object-fit: contain;
  }

  .full-width-info-banner__prop-text {
    font-family: var(--font-body--family);
    font-size: 17.88px;
    line-height: 29px;
    letter-spacing: 0.4px;
    text-align: start;
  }

  @media screen and (max-width: 749px) {
    .full-width-info-banner {
      min-height: var(--banner-height-mobile, 700px);
    }

    .full-width-info-banner__bg-image--desktop {
      display: none;
    }

    .full-width-info-banner__bg-image--mobile {
      display: block;
    }

    .full-width-info-banner__content-wrapper {
      min-height: var(--banner-height-mobile, 700px);
      padding: 0 20px 20px;
      align-items: flex-end;
      justify-content: center;
    }

    .full-width-info-banner__panel {
      padding: var(--banner-panel-padding-mobile, 30px);
      max-width: 350px;
      width: 100%;
    }

    .full-width-info-banner__heading {
      font-size: 23px;
      line-height: 27.6px;
      margin-block-end: 10px;
    }

    .full-width-info-banner__props {
      margin-block-start: 32px;
    }

    .full-width-info-banner__prop-text {
      font-size: 16px;
      line-height: 25.6px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full width info banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "number",
      "id": "min_height",
      "label": "Desktop height (px)",
      "default": 750
    },
    {
      "type": "number",
      "id": "min_height_mobile",
      "label": "Mobile height (px)",
      "default": 700
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        {
          "value": "center-left",
          "label": "Center left"
        },
        {
          "value": "center-center",
          "label": "Center"
        },
        {
          "value": "center-right",
          "label": "Center right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "center-left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "clean products that work as hard as you do"
    },
    {
      "type": "header",
      "content": "Panel"
    },
    {
      "type": "number",
      "id": "panel_padding",
      "label": "Panel padding (px)",
      "default": 40
    },
    {
      "type": "number",
      "id": "panel_padding_mobile",
      "label": "Panel padding mobile",
      "default": 30
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "prop-item",
      "name": "Prop item",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Prop item text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Full width info banner",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "prop-item",
          "settings": {
            "text": "Zero Artificial Flavors & Sweeteners"
          }
        },
        {
          "type": "prop-item",
          "settings": {
            "text": "Backed by Science"
          }
        },
        {
          "type": "prop-item",
          "settings": {
            "text": "3rd Party Tested"
          }
        },
        {
          "type": "prop-item",
          "settings": {
            "text": "Minimal Ingredients"
          }
        }
      ]
    }
  ]
}
{% endschema %}
