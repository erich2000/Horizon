<div
  class="ugc-grid spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="ugc-grid__inner">
    <div class="ugc-grid__header">
      <div class="ugc-grid__header-left">
        {% if section.settings.heading != blank %}
          <h3 class="ugc-grid__heading">{{ section.settings.heading | escape }}</h3>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="ugc-grid__description">{{ section.settings.description }}</div>
        {% endif %}
      </div>
      <div class="ugc-grid__header-right">
        {% if section.settings.social_handle_url != blank %}
          <a
            href="{{ section.settings.social_handle_url }}"
            target="_blank"
            rel="noopener noreferrer"
            class="ugc-grid__social-link"
          >
            <span class="ugc-grid__social-text">{{ section.settings.social_handle_text | escape }}</span>
          </a>
        {% elsif section.settings.social_handle_text != blank %}
          <span class="ugc-grid__social-text">{{ section.settings.social_handle_text | escape }}</span>
        {% endif %}
      </div>
    </div>

    <div class="ugc-grid__cards">
      {% for block in section.blocks %}
        <div class="ugc-grid__card" {{ block.shopify_attributes }}>
          <div class="ugc-grid__card-media">
            {% if block.settings.image_url != blank %}
              {% if block.settings.image_url contains 'instagram.com/p/' %}
                {%- assign _ig_parts = block.settings.image_url | split: '/p/' -%}
                {%- assign _ig_code = _ig_parts[1] | split: '/' | first -%}
                <div class="ugc-grid__ig-wrapper">
                  <iframe
                    src="https://www.instagram.com/p/{{ _ig_code }}/embed/?img_index=1"
                    class="ugc-grid__ig-embed"
                    frameborder="0"
                    scrolling="no"
                    allowtransparency="true"
                    loading="lazy"
                    title="Instagram post"
                  ></iframe>
                </div>
              {% else %}
                <img
                  src="{{ block.settings.image_url }}"
                  alt="{{ block.settings.caption | truncate: 80 | escape }}"
                  class="ugc-grid__image"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                >
              {% endif %}
            {% elsif block.settings.image != blank %}
              {%- assign sizes_val = '(min-width: 750px) 25vw, 50vw' -%}
              {{
                block.settings.image
                | image_url: width: block.settings.image.width
                | image_tag:
                  sizes: sizes_val,
                  widths: '175,315,375,550,750',
                  loading: 'lazy',
                  class: 'ugc-grid__image',
                  alt: block.settings.image.alt
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'ugc-grid__placeholder' }}
            {% endif %}
          </div>

          {% if block.settings.caption != blank %}
            <div class="ugc-grid__overlay">
              <p class="ugc-grid__caption">{{ block.settings.caption | escape }}</p>
            </div>
          {% endif %}

          {% if block.settings.link != blank %}
            <a
              href="{{ block.settings.link }}"
              target="_blank"
              rel="noopener noreferrer"
              class="ugc-grid__card-link"
              aria-label="View post"
            ></a>
          {% endif %}

          {% if block.settings.caption != blank %}
            <button type="button" class="ugc-grid__expand-btn" aria-label="Expand post caption">
              <svg width="16" height="16" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4.5" y="1" width="1" height="8" fill="currentColor"/>
                <rect x="1" y="4.5" width="8" height="1" fill="currentColor"/>
              </svg>
            </button>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    root.addEventListener('click', function(e) {
      var button = e.target.closest('.ugc-grid__expand-btn');
      if (!button) return;
      var card = button.closest('.ugc-grid__card');
      if (!card) return;
      card.classList.toggle('is-expanded');
    });
  })();
</script>

{% stylesheet %}
  /* Inner container — horizontal padding */
  .ugc-grid__inner {
    padding-inline: 70px;
  }

  /* Header — row layout on desktop */
  .ugc-grid__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-block-end: 48px;
  }

  /* Header left — constrain width to match source */
  .ugc-grid__header-left {
    max-width: 367px;
  }

  /* Heading */
  .ugc-grid__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 24px;
    line-height: 29px;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    margin: 0 0 20px 0;
  }

  /* Description richtext */
  .ugc-grid__description {
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-size: 16px;
    line-height: 25.6px;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    max-width: 367px;
  }

  .ugc-grid__description p {
    margin: 0;
  }

  .ugc-grid__description a {
    color: var(--color-foreground);
    text-decoration: none;
  }

  .ugc-grid__description a:hover {
    text-decoration: underline;
  }

  /* Social handle link */
  .ugc-grid__social-link {
    text-decoration: none;
    color: var(--color-foreground-heading);
  }

  .ugc-grid__social-link:focus-visible {
    outline: 1px auto var(--color-foreground);
    outline-offset: 1px;
  }

  /* Social handle text — desktop appearance */
  .ugc-grid__social-text {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 24px;
    line-height: 29px;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  /* Cards grid — 4 columns on desktop */
  .ugc-grid__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-block-end: 48px;
  }

  /* Card container */
  .ugc-grid__card {
    position: relative;
    overflow: hidden;
  }

  /* Card media wrapper */
  .ugc-grid__card-media {
    position: relative;
    width: 100%;
  }

  /* Card image — square aspect ratio */
  .ugc-grid__image {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  /* Placeholder when no image set */
  .ugc-grid__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
  }

  /* Instagram embed wrapper — crops to square, hiding the profile header */
  .ugc-grid__ig-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  /* Solid strips over the left/right edges — covers Instagram's nav arrow buttons */
  .ugc-grid__ig-wrapper::before,
  .ugc-grid__ig-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 1;
    background: var(--color-background);
    pointer-events: none;
  }

  .ugc-grid__ig-wrapper::before {
    left: 0;
  }

  .ugc-grid__ig-wrapper::after {
    right: 0;
  }

  /* Iframe offset: -62px hides the profile pic/username row at the top */
  .ugc-grid__ig-embed {
    position: absolute;
    top: -62px;
    left: -1px;
    width: calc(100% + 2px);
    height: calc(100% + 130px);
    border: none;
    pointer-events: none;
  }

  /* Caption overlay — hidden by default */
  .ugc-grid__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
    padding: 20px;
  }

  /* Show overlay on hover (pointer devices only) */
  @media (hover: hover) {
    .ugc-grid__card:hover .ugc-grid__overlay {
      opacity: 1;
    }
  }

  /* Show overlay on keyboard focus */
  .ugc-grid__card:focus-within .ugc-grid__overlay {
    opacity: 1;
  }

  /* Show overlay when expanded via button */
  .ugc-grid__card.is-expanded .ugc-grid__overlay {
    opacity: 1;
  }

  /* Caption text */
  .ugc-grid__caption {
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-size: 16px;
    line-height: 25.6px;
    letter-spacing: 0.4px;
    color: var(--color-foreground);
    text-align: center;
    margin: 0;
  }

  /* Full-coverage card link */
  .ugc-grid__card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
    text-decoration: none;
  }

  .ugc-grid__card-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: -2px;
  }

  /* Expand button — hidden on desktop by default */
  .ugc-grid__expand-btn {
    display: none;
  }

  /* ===== Mobile styles (≤749px) ===== */
  @media screen and (max-width: 749px) {
    .ugc-grid__inner {
      padding-inline: 12px;
    }

    /* Header stacks vertically and centers */
    .ugc-grid__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-block-end: 0;
    }

    .ugc-grid__header-left {
      max-width: none;
    }

    .ugc-grid__heading {
      font-size: 23px;
      line-height: 28px;
      margin-block-end: 10px;
    }

    .ugc-grid__description {
      max-width: none;
    }

    /* Social handle spacing within stacked header */
    .ugc-grid__header-right {
      margin-block-start: 12px;
      margin-block-end: 32px;
    }

    /* Social handle — smaller, subheading font on mobile */
    .ugc-grid__social-text {
      font-family: var(--font-subheading--family);
      font-style: var(--font-subheading--style);
      font-weight: 800;
      font-size: 10px;
      line-height: 18px;
      letter-spacing: 1.7px;
    }

    /* Cards grid — 2 columns on mobile */
    .ugc-grid__cards {
      grid-template-columns: repeat(2, 1fr);
      margin-block-end: 0;
    }

    /* Expand button — visible on mobile */
    .ugc-grid__expand-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      bottom: 10px;
      right: 10px;
      width: 34px;
      height: 34px;
      padding: 0;
      border-radius: 50%;
      border: 1px solid var(--color-foreground);
      background-color: var(--color-background);
      color: var(--color-foreground);
      cursor: pointer;
      z-index: 3;
      appearance: none;
    }

    .ugc-grid__expand-btn:focus-visible {
      outline: 2px solid var(--color-foreground);
      outline-offset: 2px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "UGC grid",
  "class": "ugc-grid-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apply To Become an Ascent Athlete"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Love Ascent and want to represent the hardest working brand online? <a href=\"/pages/ambassador-application\"><strong>Apply</strong></a> to become an Ascent Athlete!</p>"
    },
    {
      "type": "text",
      "id": "social_handle_text",
      "label": "Social handle text",
      "default": "@ascent_protein"
    },
    {
      "type": "url",
      "id": "social_handle_url",
      "label": "Social handle link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 94,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 94,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "image_url",
          "label": "External image URL",
          "info": "Paste an Instagram post URL (e.g. instagram.com/p/…) or a direct image URL. Takes priority over the image picker below."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC grid",
      "blocks": {
        "card_1": {
          "type": "card",
          "settings": {
            "caption": "Huge shout out to @ascentprotein for supporting my journey for the last 6 YEARS. No matter what, the quality is always top-notch."
          }
        },
        "card_2": {
          "type": "card",
          "settings": {
            "caption": "Part II: bike ride — 122 miles, 7000' of gain, 7 hour and 34 minutes. Thanks @ascent_protein!"
          }
        },
        "card_3": {
          "type": "card",
          "settings": {
            "caption": "@ascent_protein with me every step of the way — keeping me right and helping me bounce back stronger."
          }
        },
        "card_4": {
          "type": "card",
          "settings": {
            "caption": "I choose Ascent products because I know exactly what goes into them - all CLEAN ingredients!!"
          }
        }
      },
      "block_order": ["card_1", "card_2", "card_3", "card_4"]
    }
  ]
}
{% endschema %}
